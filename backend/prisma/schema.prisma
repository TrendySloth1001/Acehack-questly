// ─── Questly Prisma Schema ───
// Scalable domain-specific schema with optimised relations

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────
// Auth Domain
// ──────────────────────────────

enum AuthProvider {
  LOCAL
  GOOGLE
  GITHUB
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  avatarUrl     String?
  password      String?      // null for OAuth-only users
  phone         String?
  reason        String?
  skills        String[]     @default([])
  location      String?
  latitude      Float?
  longitude     Float?
  role          Role         @default(USER)
  walletAddress String?
  walletMnemonic String?      // custodial-wallet recovery phrase (encrypted at rest)
  isActive      Boolean      @default(true)
  emailVerified Boolean      @default(false)
  onboarded     Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Relations
  accounts       Account[]
  refreshTokens  RefreshToken[]
  quests         Quest[]
  uploads        Upload[]
  bounties       Bounty[]
  bountyClaims   BountyClaim[]
  walletTxns     WalletTransaction[]

  @@index([email])
  @@map("users")
}

model Account {
  id                String       @id @default(cuid())
  userId            String
  provider          AuthProvider
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?
  createdAt         DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ──────────────────────────────
// Quest Domain (core feature)
// ──────────────────────────────

enum QuestStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

model Quest {
  id          String      @id @default(cuid())
  title       String
  description String?
  status      QuestStatus @default(DRAFT)
  userId      String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([userId])
  @@index([status])
  @@map("quests")
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  isCompleted Boolean  @default(false)
  order       Int      @default(0)
  questId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quest Quest @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@index([questId])
  @@map("tasks")
}

// ──────────────────────────────
// Upload Domain (MinIO / S3)
// ──────────────────────────────

model Upload {
  id         String   @id @default(cuid())
  fileName   String
  mimeType   String
  size       Int
  bucket     String
  objectKey  String   @unique
  url        String
  userId     String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("uploads")
}

// ──────────────────────────────
// Bounty Domain (Micro-Task Board)
// ──────────────────────────────

enum BountyStatus {
  OPEN
  CLAIMED
  IN_REVIEW
  COMPLETED
  CANCELLED
}

enum ClaimStatus {
  ACTIVE
  SUBMITTED
  APPROVED
  REJECTED
}

enum EscrowStatus {
  UNFUNDED
  FUNDED
  RELEASED
  REFUNDED
}

model Bounty {
  id          String       @id @default(cuid())
  creatorId   String
  title       String
  description String
  category    String
  algoAmount  Float        @default(0)
  deadline    DateTime
  status      BountyStatus @default(OPEN)
  latitude    Float?
  longitude   Float?
  location    String?

  // Images uploaded via MinIO
  imageUrls   String[]     @default([])

  // Dynamic extra fields the creator added (stored as JSON)
  extraFields Json?

  // Algorand escrow
  escrowTxId    String?
  escrowStatus  EscrowStatus @default(UNFUNDED)
  refundTxId    String?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  creator     User         @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  claims      BountyClaim[]

  @@index([creatorId])
  @@index([status])
  @@index([deadline])
  @@map("bounties")
}

model BountyClaim {
  id          String      @id @default(cuid())
  bountyId    String
  claimerId   String
  status      ClaimStatus @default(ACTIVE)
  proofUrl    String?
  note        String?
  paymentTxId String?
  submittedAt DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime    @default(now())

  bounty      Bounty      @relation(fields: [bountyId], references: [id], onDelete: Cascade)
  claimer     User        @relation(fields: [claimerId], references: [id], onDelete: Cascade)

  @@unique([bountyId, claimerId])
  @@index([bountyId])
  @@index([claimerId])
  @@map("bounty_claims")
}

// ──────────────────────────────
// Wallet Transaction History
// ──────────────────────────────

enum TxType {
  DEBIT   // ALGO sent out (e.g. fund escrow)
  CREDIT  // ALGO received (e.g. escrow release)
}

model WalletTransaction {
  id                 String   @id @default(cuid())
  userId             String
  type               TxType
  amountAlgo         Float
  txId               String?              // on-chain txn id
  bountyId           String?
  bountyTitle        String?
  counterpartyAddress String?             // who sent / who received
  description        String
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("wallet_transactions")
}
